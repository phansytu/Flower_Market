# ──────────────────────────────────────────────────────────────────
# Flower Marketplace – Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to source control.
# ──────────────────────────────────────────────────────────────────

# Spring
SPRING_PROFILES_ACTIVE=prod

# Application port
APP_PORT=8080

# ── MySQL ──────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me_root
DB_NAME=flower_marketplace
DB_USERNAME=flower_user
DB_PASSWORD=change_me_db
MYSQL_PORT=3306

# ── Redis ──────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_PASSWORD=

# ── RabbitMQ ───────────────────────────────────────────────────────
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# ── Elasticsearch ──────────────────────────────────────────────────
ES_PORT=9200

# ── Kibana (monitoring profile) ────────────────────────────────────
KIBANA_PORT=5601
KIBANA_PASSWORD=kibana_pass

# ── JWT ────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_HEX_SECRET

# ── Mail ───────────────────────────────────────────────────────────
# For dev, keep MAIL_HOST=mailhog and start with --profile dev
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
# For production (e.g. Gmail):
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password
