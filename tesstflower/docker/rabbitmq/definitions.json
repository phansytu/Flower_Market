{
  "vhosts": [{ "name": "/" }],
  "exchanges": [
    {
      "name": "flower.notification.exchange",
      "vhost": "/",
      "type": "topic",
      "durable": true,
      "auto_delete": false
    },
    {
      "name": "flower.order.exchange",
      "vhost": "/",
      "type": "topic",
      "durable": true,
      "auto_delete": false
    }
  ],
  "queues": [
    { "name": "flower.email.queue",             "vhost": "/", "durable": true, "auto_delete": false,
      "arguments": { "x-message-ttl": 86400000, "x-dead-letter-exchange": "flower.dlx" } },
    { "name": "flower.order.status.queue",      "vhost": "/", "durable": true, "auto_delete": false,
      "arguments": { "x-message-ttl": 86400000, "x-dead-letter-exchange": "flower.dlx" } },
    { "name": "flower.push.notification.queue", "vhost": "/", "durable": true, "auto_delete": false,
      "arguments": { "x-message-ttl": 86400000, "x-dead-letter-exchange": "flower.dlx" } },
    { "name": "flower.dlq",                     "vhost": "/", "durable": true, "auto_delete": false,
      "arguments": {} }
  ],
  "bindings": [
    { "source": "flower.notification.exchange", "vhost": "/", "destination": "flower.email.queue",
      "destination_type": "queue", "routing_key": "flower.email", "arguments": {} },
    { "source": "flower.order.exchange",        "vhost": "/", "destination": "flower.order.status.queue",
      "destination_type": "queue", "routing_key": "flower.order.status", "arguments": {} },
    { "source": "flower.notification.exchange", "vhost": "/", "destination": "flower.push.notification.queue",
      "destination_type": "queue", "routing_key": "flower.push", "arguments": {} }
  ]
}
